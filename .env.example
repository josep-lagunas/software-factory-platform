# SFP environment variables template.
#
# Copy this file to .env (gitignored) and fill in real values:
#     cp .env.example .env
#
# Lines need NO `export` prefix — source-env.sh loads .env with auto-export
# (`set -a`), so every key becomes an environment variable regardless.
#
# NEVER commit real secrets. Only placeholders live here.

# ── Jira ────────────────────────────────────────────
JIRA_SITE=https://example.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=replace-with-jira-token
JIRA_PROJECT=SFP

# ── Anthropic ───────────────────────────────────────
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=replace-with-anthropic-token

# ── GitHub ──────────────────────────────────────────
GITHUB_TOKEN_CODER=replace-with-coder-pat
GITHUB_TOKEN_REVIEWER=replace-with-reviewer-pat
