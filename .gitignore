# ── Secrets — NEVER commit ──────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets.*
# sfp_config's SecretRef is a value-free reference type (ID-016, MAS §10.8);
# un-ignore that module while keeping real secret material out of git.
!packages/sfp-config/src/sfp_config/secrets.py

# ── Jira upload run state ───────────────────────────
.jira_creation_state.json

# ── Python ──────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# NOTE: uv.lock SHOULD be committed — do NOT ignore it.

# ── OS / editors ────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp

# ── Claude Code local override (machine-specific) ──
.claude/settings.local.json
